# Environment Variables Template
# Copy this to nirmalajewellers/.env and update with your actual values

# Django Settings
DJANGO_ENV=local
DEBUG=False
SECRET_KEY=your-secure-random-key-here (generate using: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())")
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# Database Configuration
DATABASE_NAME=nirmalajewellers_db
DATABASE_USER=nirmalajewellers_user
DATABASE_PASSWORD=probook
DATABASE_HOST=localhost
DATABASE_PORT=5432

# Allowed Hosts
ALLOWED_HOSTS=nirmalajewellers.net,www.nirmalajewellers.net,localhost,127.0.0.1

# Cloudinary Configuration (Image Storage)
CLOUDINARY_CLOUD_NAME=dutjtpdhn
CLOUDINARY_API_KEY=891116228766476
CLOUDINARY_API_SECRET=dHak4tSRQb5PctRTS5qEClOHXis

# CORS Settings (if needed for APIs)
CORS_ALLOWED_ORIGINS=https://nirmalajewellers.net,https://www.nirmalajewellers.net

# Slack alerting for daily page performance checks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
SLACK_CHANNEL=#new-channel
SLACK_USERNAME=Nirmala Page Monitor
SLACK_ICON_EMOJI=:warning:

# Daily page performance monitor
PAGE_MONITOR_BASE_URL=https://nirmalajewellers.net
PAGE_MONITOR_THRESHOLD_MS=3000
PAGE_MONITOR_TIMEOUT_SECONDS=20
# Leave PAGE_MONITOR_PATHS empty to auto-discover static page URLs from Django.
PAGE_MONITOR_PATHS=
# Add dynamic pages that need real IDs, for example: /products/1/,/shop/category/2/
PAGE_MONITOR_EXTRA_PATHS=
PAGE_MONITOR_SKIP_PATHS=
PAGE_MONITOR_NOTIFY_ON_SUCCESS=False
# Optional: enables authenticated page checks in addition to public pages.
MONITOR_USERNAME=
MONITOR_PASSWORD=
